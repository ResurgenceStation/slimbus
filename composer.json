{
    "repositories": [
      {
        "type":"git",
        "url":"https://github.com/nfreader/easydb"
      }
    ],
    "require": {
        "php": ">=7.2.0",
        "slim/slim": "^3.12",
        "slim/php-view": "^2.0",
        "vlucas/phpdotenv": "^2.6",
        "paragonie/easydb": "@dev",
        "slim/twig-view": "^2.0",
        "guzzlehttp/guzzle": "^6.3",
        "erusev/parsedown": "^1.7",
        "kevinrob/guzzle-cache-middleware": "^3.2",
        "league/flysystem": "^1.0",
        "doctrine/cache": "^1.7",
        "slim/csrf": "^0.8"
    },
    "autoload": {
        "psr-4": {
            "Statbus\\": "src/Statbus/"
        }
    },
    "config": {
        "audit": {
            "block-insecure": false
        }
    }
}
